# Supabase/Postgres database connection.
# Use the database connection string from Supabase Project Settings -> Database.
# Do not use the public project API URL here.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Needed for Supabase Realtime in the Pixel-Place browser client.
# These values are public, but keeping them configurable makes deployments easier.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
